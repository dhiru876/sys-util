# ============================================================
# SysUtil — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it's in .gitignore.
# ============================================================

# App backend endpoint (leave as localhost if running offline)
APP_ENDPOINT=http://localhost:3000

# API access key for backend (leave as dummy if running offline)
API_ACCESS_KEY=dummy_offline_mode

# Payment endpoint (leave as localhost if running offline)
PAYMENT_ENDPOINT=http://localhost:3000

# PostHog analytics key (optional — leave empty to disable)
POSTHOG_API_KEY=
